{
  "$schema": "https://pocketjs.dev/schema/pocket-2.json",
  "pocket": 2,
  "id": "dev.pocket-stack.figma",
  "name": "pocket-figma",
  "title": "Pocket Figma",
  "version": "0.1.0",
  "engine": {
    "capabilities": {
      "requires": [
        "text.glyphs.baked",
        "input.buttons",
        "input.analog.left"
      ],
      "enhances": [
        "input.touch"
      ]
    }
  },
  "app": {
    "entry": "app/main.tsx",
    "output": "main",
    "framework": "solid",
    "viewport": {
      "logical": [480, 272],
      "presentation": "integer-fit"
    }
  }
}
